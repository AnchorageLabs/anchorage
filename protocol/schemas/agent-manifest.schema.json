{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchorage.dev/schemas/agent-manifest.schema.json",
  "title": "Anchorage Agent Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "protocolVersion", "taskTypes", "requires", "binary"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "protocolVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "taskTypes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/taskType"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requires": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "binary": {
      "type": "string",
      "minLength": 1
    },
    "timeout": {
      "type": "integer",
      "minimum": 1
    }
  },
  "$defs": {
    "taskType": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
    },
    "capability": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*$"
    }
  }
}
