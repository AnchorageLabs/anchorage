{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anchorage.dev/schemas/artifact-reference.schema.json",
  "title": "Anchorage Artifact Reference",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifactType", "uri"],
  "properties": {
    "artifactType": {
      "type": "string",
      "minLength": 1
    },
    "uri": {
      "type": "string",
      "minLength": 1
    },
    "mediaType": {
      "type": "string",
      "minLength": 1
    },
    "sizeBytes": {
      "type": "integer",
      "minimum": 0
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    }
  }
}
