{
  "name": "gitlab-reader",
  "version": "0.1.0",
  "protocolVersion": "0.1",
  "description": "Reads a GitLab issue and emits a structured issue summary.",
  "taskTypes": ["gitlab.task.read"],
  "inputs": ["gitlab.issue"],
  "outputs": ["issue.summary"],
  "requires": ["gitlab.read"],
  "binary": "./dist/index.js",
  "timeout": 300
}
