{
  "name": "gitlab-pr-opener",
  "version": "0.1.0",
  "protocolVersion": "0.1",
  "description": "Pushes the branch and opens a GitLab merge request.",
  "taskTypes": ["gitlab.merge_request.open"],
  "inputs": ["code.change.result"],
  "outputs": ["pr.opened"],
  "requires": ["gitlab.write", "workspace.write", "shell.exec"],
  "binary": "./dist/index.js",
  "timeout": 300
}
