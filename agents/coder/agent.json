{
  "name": "coder",
  "version": "0.1.0",
  "protocolVersion": "0.1",
  "description": "Applies implementation plans by calling a configured LLM provider and writing workspace changes.",
  "taskTypes": ["code.change"],
  "inputs": ["implementation.plan"],
  "outputs": ["code.change.result"],
  "requires": ["workspace.write", "llm.code", "shell.exec", "repo.read", "web.read"],
  "binary": "./dist/index.js",
  "timeout": 900
}
